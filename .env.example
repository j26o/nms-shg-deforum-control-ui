# Local Automatic1111 source path for resolving bundled image references.
VITE_SOURCE_ASSET_ROOT=D:\nms-shg-deforum-control-ui-main\assets\images\source

# Optional Hugging Face Deforum backend.
# Keep the token out of browser code. The Vite dev proxy reads this server-side.
# If HF_TOKEN is omitted, the proxy tries the named Hugging Face CLI cache token.
HF_TOKEN_NAME=nms-shg
# HF_TOKEN=hf_xxx
# HUGGING_FACE_HUB_TOKEN=hf_xxx

# Dedicated endpoint or private Space/API base URL for a Deforum-compatible backend.
# Defaults expect POST /jobs, GET /jobs/:id, and GET /jobs/:id/artifact.
HF_DEFORUM_ENDPOINT_URL=
HF_DEFORUM_SUBMIT_PATH=/jobs
HF_DEFORUM_STATUS_PATH_TEMPLATE=/jobs/:id
HF_DEFORUM_ARTIFACT_PATH_TEMPLATE=/jobs/:id/artifact

# Set to 0 only if the remote endpoint can resolve repo-relative image paths itself.
HF_DEFORUM_INCLUDE_IMAGE_DATA=1
